# Copy to .env — never commit .env

PORT=8082
CORS_ORIGINS=*

# Option A: direct SQLAlchemy URL
# DATABASE_URL=postgresql://postgres.xxx:password@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?sslmode=require

# Option B: JDBC-style (converted automatically)
SUPABASE_DB_URL="jdbc:postgresql://aws-0-ap-south-1.pooler.supabase.com:6543/postgres?sslmode=require&prepareThreshold=0"
SUPABASE_DB_USER=postgres.xxx
SUPABASE_DB_PASSWORD='your-database-password'

# Supabase (optional — JWT verify later)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=

# Razorpay (optional)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# App defaults
FREE_DELIVERY_THRESHOLD=499
DELIVERY_CHARGE=49

# OTP (dev — fixed code for email/phone verification)
DEV_OTP=12345
OTP_EXPIRY_MINUTES=5
